# ============================================================
#  Эпатаж — пример переменных окружения
#  Скопируйте в .env и заполните реальными значениями.
#  .env в git НЕ коммитится.
# ============================================================

# --- Общее ---
PROJECT_NAME=Эпатаж
ENVIRONMENT=local          # local | production
DEBUG=True                 # на production обязательно False

# --- База данных (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/shop

# --- Безопасность ---
# Сгенерировать: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- ЮKassa (приём оплаты) ---
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
# Код НДС для чеков: 1 = без НДС (УСН), 3 = НДС 10%, 4 = НДС 20%
RECEIPT_VAT_CODE=1

# Система налогообложения (СНО) в чеке. Заполнять, ТОЛЬКО если в ЛК YooKassa
# настроено несколько СНО. При одной — оставить пустым (YooKassa подставит сама).
# Коды: 1=ОСН, 2=УСН доход, 3=УСН доход-расход, 5=ЕСХН, 6=Патент
# RECEIPT_TAX_SYSTEM_CODE=2

# --- СДЭК (доставка) ---
# Тестовые ключи (публичные) уже подставлены ниже — годятся для разработки.
# Боевые: CDEK_API_URL=https://api.cdek.ru + ключи из lk.cdek.ru/integration
CDEK_API_URL=https://api.edu.cdek.ru
CDEK_ACCOUNT=wqGwiQx0gg8mLtiEKsUinjVSICCjtTEP
CDEK_SECURE_PASSWORD=RmAmgvSgSl1yirlz9QupbzOJVqhCxcP5
CDEK_SENDER_CITY_NAME=Тамбов
CDEK_SENDER_CITY_CODE=298
CDEK_SENDER_POSTAL_CODE=392000
CDEK_COURIER_ENABLED=false
CDEK_AUTO_STATUS=true   # статусы меняются автоматически

# --- Почта (SMTP) — письма покупателям (ящик epatajextra.ru на reg.ru) ---
EMAILS_ENABLED=False
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Магазин Эпатаж

