# Окружение: local или production
ENVIRONMENT=local
DEBUG=True
PROJECT_NAME=Эпатаж

# База данных (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/shop

# Секретный ключ — на проде ОБЯЗАТЕЛЬНО сгенерировать новый!
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_URL=redis://redis:6379/0

# YooKassa — на проде боевые ключи реального магазина
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Почта (SMTP) — письма покупателям
# Для реальной отправки: EMAILS_ENABLED=True и заполнить остальное
EMAILS_ENABLED=False
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=